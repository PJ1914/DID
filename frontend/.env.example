# Next.js Environment Variables
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key_here
NEXT_PUBLIC_INFURA_PROJECT_ID=your_infura_project_id_here

# Network Configuration
NEXT_PUBLIC_DEFAULT_CHAIN_ID=11155111
NEXT_PUBLIC_ENABLE_TESTNETS=true

# IPFS Configuration
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud
NEXT_PUBLIC_PINATA_API_KEY=your_pinata_api_key
NEXT_PUBLIC_PINATA_SECRET_KEY=your_pinata_secret_key

# Contract Addresses (Update these with your deployed contracts)
NEXT_PUBLIC_IDENTITY_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_TRUST_SCORE_ADDRESS=0x...
NEXT_PUBLIC_VERIFICATION_MANAGER_ADDRESS=0x...
NEXT_PUBLIC_ZK_PROOF_MANAGER_ADDRESS=0x...
NEXT_PUBLIC_ORGANIZATION_MANAGER_ADDRESS=0x...
NEXT_PUBLIC_CERTIFICATE_MANAGER_ADDRESS=0x...

# Analytics (Optional)
NEXT_PUBLIC_GA_TRACKING_ID=your_ga_id
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token

# Feature Flags
NEXT_PUBLIC_ENABLE_ZK_PROOFS=true
NEXT_PUBLIC_ENABLE_ORGANIZATIONS=true
NEXT_PUBLIC_ENABLE_ACCOUNT_ABSTRACTION=true