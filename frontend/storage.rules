rules_version = '2';

// Firebase Storage Security Rules for BC-CVS Certificate System
// Deploy these rules via Firebase Console: Storage → Rules
service firebase.storage {
  match /b/{bucket}/o {
    
    // =========================================
    // CERTIFICATES FOLDER
    // =========================================
    match /certificates/{fileName} {
      // Public read - anyone can download/verify certificates
      allow read: if true;
      
      // Open write for development/testing
      // For production, add wallet address validation
      allow write: if true;
    }
    
    // =========================================
    // PROFILE IMAGES
    // =========================================
    match /profile-images/{fileName} {
      allow read: if true;
      allow write: if true;
    }
    
    // =========================================
    // INSTITUTION LOGOS
    // =========================================
    match /institution-logos/{fileName} {
      allow read: if true;
      allow write: if true;
    }
  }
}

// =============================================================================
// DEPLOYMENT INSTRUCTIONS
// =============================================================================
// 1. Open Firebase Console: https://console.firebase.google.com/
// 2. Select your project: blockchain-project-39a23
// 3. Go to: Storage → Rules tab (left sidebar)
// 4. Copy the rules above (lines 1-34)
// 5. Paste into the Firebase Console editor
// 6. Click "Publish" button
// 7. Wait for "Rules published successfully" message
// 8. Retry your certificate upload
//
