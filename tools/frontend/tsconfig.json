{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "dom",
            "dom.iterable",
            "es2022"
        ],
        "allowJs": false,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "ESNext",
        "moduleResolution": "Node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "types": [
            "jest",
            "node"
        ],
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@/app/*": [
                "./app/*"
            ],
            "@/components/*": [
                "./components/*"
            ],
            "@/lib/*": [
                "./src/lib/*"
            ],
            "@/hooks/*": [
                "./src/hooks/*"
            ],
            "@/store/*": [
                "./src/store/*"
            ],
            "@/types/*": [
                "./src/types/*"
            ],
            "@/utils/*": [
                "./src/utils/*"
            ]
        },
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ]
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        "**/*.cjs",
        "**/*.mjs",
        "**/*.cts",
        "**/*.mts",
        ".next/types/**/*.ts",
        "types/**/*.d.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}